{
  "name": "carsync-expense-backend",
  "version": "1.0.0",
  "description": "CarSync - Production-ready expense backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
