// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  INSURANCE
  CAR_WASH
  PARKING
  TOLL
  OTHER
}

enum ServiceStatus {
  COMPLETED
  SCHEDULED
  UPCOMING
}

model Expense {
  id        String   @id @default(uuid())
  userEmail String?
  category  ExpenseCategory
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userEmail])
  @@index([createdAt])
  @@index([category])
}

model Service {
  id          String        @id @default(uuid())
  userEmail   String?
  serviceType String
  date        DateTime
  notes       String?
  status      ServiceStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userEmail])
  @@index([date])
  @@index([status])
  @@index([createdAt])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}
